# PulseLite Environment Variables
# Copy this file to .env and fill in your values

# Kafka Configuration
KAFKA_SERVER=localhost:9092
KAFKA_TOPIC_NEW=hn-posts
KAFKA_TOPIC_TOP=hn-top

# Schema Registry
SCHEMA_REGISTRY_URL=http://localhost:8081

# Dashboard
REFRESH_INTERVAL_SECONDS=20
DEMO_MODE=false

# Anomaly Detection
ANOMALY_THRESHOLD=3.0
DRIFT_THRESHOLD=0.3

# Pulse Digest (processor/digest_generator.py)
# Optional - if unset, the digest falls back to a rule-based summary
# instead of calling the Anthropic API, so the pipeline never hard-fails
# for lack of a key.
ANTHROPIC_API_KEY=
DIGEST_MODEL=claude-haiku-4-5-20251001
DIGEST_INTERVAL_SECONDS=300